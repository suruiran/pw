{
    "exe": "docker",
    "description": "Docker container management CLI",
    "args": [
        {
            "name": "--config",
            "description": "Location of client config files",
            "kind": "filepath",
            "globs": [
                "*"
            ],
            "dir_only": true
        },
        {
            "name": "--context",
            "description": "Name of the context to use",
            "kind": "str"
        },
        {
            "name": "--debug",
            "description": "Enable debug mode",
            "kind": "flag"
        },
        {
            "name": "--host",
            "description": "Daemon socket to connect to",
            "kind": "str",
            "repeatable": true
        },
        {
            "name": "--log-level",
            "description": "Set logging level",
            "kind": "select",
            "options": [
                "trace",
                "debug",
                "info",
                "warn",
                "error",
                "fatal"
            ],
            "allow_custom": false
        },
        {
            "name": "--tls",
            "description": "Use TLS",
            "kind": "flag"
        },
        {
            "name": "--tlscacert",
            "description": "Trust certs signed only by this CA",
            "kind": "filepath",
            "globs": [
                "*.pem",
                "*.crt"
            ],
            "dir_only": false,
            "depends_on": [
                "--tls"
            ]
        },
        {
            "name": "--tlscert",
            "description": "Path to TLS certificate file",
            "kind": "filepath",
            "globs": [
                "*.pem",
                "*.crt"
            ],
            "dir_only": false,
            "depends_on": [
                "--tls"
            ]
        },
        {
            "name": "--tlskey",
            "description": "Path to TLS key file",
            "kind": "filepath",
            "globs": [
                "*.pem",
                "*.key"
            ],
            "dir_only": false,
            "depends_on": [
                "--tls"
            ]
        },
        {
            "name": "--tlsverify",
            "description": "Use TLS and verify remote",
            "kind": "flag",
            "depends_on": [
                "--tls"
            ]
        },
        {
            "name": "--version",
            "description": "Print version information and quit",
            "kind": "flag"
        }
    ],
    "subs": {
        "build": {
            "exe": "build",
            "description": "Build an image from a Dockerfile",
            "args": [
                {
                    "name": "--file",
                    "description": "Name of the Dockerfile",
                    "kind": "filepath",
                    "globs": [
                        "Dockerfile*",
                        "*.dockerfile"
                    ],
                    "dir_only": false
                },
                {
                    "name": "--tag",
                    "description": "Name and optionally a tag",
                    "kind": "str",
                    "repeatable": true
                },
                {
                    "name": "--build-arg",
                    "description": "Set build-time variables",
                    "kind": "pairs",
                    "key": [],
                    "allow_custom_key": true,
                    "sep": "=",
                    "value": {
                        "kind": "str"
                    },
                    "repeatable": true
                },
                {
                    "name": "--no-cache",
                    "description": "Do not use cache when building",
                    "kind": "flag"
                },
                {
                    "name": "context",
                    "description": "Build context path",
                    "required": true,
                    "kind": "filepath",
                    "globs": [
                        "*"
                    ],
                    "dir_only": true
                }
            ]
        },
        "run": {
            "exe": "run",
            "description": "Run a command in a new container",
            "args": [
                {
                    "name": "--detach",
                    "description": "Run container in background",
                    "kind": "flag"
                },
                {
                    "name": "--env",
                    "description": "Set environment variables",
                    "kind": "pairs",
                    "key": [],
                    "allow_custom_key": true,
                    "sep": "=",
                    "value": {
                        "kind": "str"
                    },
                    "repeatable": true
                },
                {
                    "name": "--publish",
                    "description": "Publish container ports",
                    "kind": "str",
                    "repeatable": true
                },
                {
                    "name": "--volume",
                    "description": "Bind mount a volume",
                    "kind": "str",
                    "repeatable": true
                },
                {
                    "name": "--rm",
                    "description": "Automatically remove container when it exits",
                    "kind": "flag"
                },
                {
                    "name": "--name",
                    "description": "Assign a name to the container",
                    "kind": "str"
                },
                {
                    "name": "image",
                    "description": "Image to run",
                    "required": true,
                    "kind": "str"
                },
                {
                    "name": "command",
                    "description": "Command to execute in container",
                    "kind": "str"
                }
            ]
        },
        "exec": {
            "exe": "exec",
            "description": "Run a command in a running container",
            "args": [
                {
                    "name": "--detach",
                    "description": "Run command in background",
                    "kind": "flag"
                },
                {
                    "name": "--env",
                    "description": "Set environment variables",
                    "kind": "pairs",
                    "key": [],
                    "allow_custom_key": true,
                    "sep": "=",
                    "value": {
                        "kind": "str"
                    },
                    "repeatable": true
                },
                {
                    "name": "--interactive",
                    "description": "Keep STDIN open",
                    "kind": "flag"
                },
                {
                    "name": "--tty",
                    "description": "Allocate a pseudo-TTY",
                    "kind": "flag"
                },
                {
                    "name": "container",
                    "description": "Container name or ID",
                    "required": true,
                    "kind": "str"
                },
                {
                    "name": "command",
                    "description": "Command to execute",
                    "required": true,
                    "kind": "str"
                }
            ]
        }
    },
    "pull": {
        "exe": "pull",
        "description": "Pull an image from a registry",
        "args": [
            {
                "name": "--all-tags",
                "description": "Download all tagged images",
                "kind": "flag"
            },
            {
                "name": "image",
                "description": "Image name",
                "required": true,
                "kind": "str"
            }
        ]
    },
    "push": {
        "exe": "push",
        "description": "Push an image to a registry",
        "args": [
            {
                "name": "--all-tags",
                "description": "Push all tags",
                "kind": "flag"
            },
            {
                "name": "image",
                "description": "Image name",
                "required": true,
                "kind": "str"
            }
        ]
    },
    "images": {
        "exe": "images",
        "description": "List images"
    },
    "ps": {
        "exe": "ps",
        "description": "List containers",
        "args": [
            {
                "name": "--all",
                "description": "Show all containers",
                "kind": "flag"
            }
        ]
    },
    "stop": {
        "exe": "stop",
        "description": "Stop running containers",
        "args": [
            {
                "name": "--time",
                "description": "Seconds to wait before killing",
                "kind": "number",
                "int": true,
                "min": 0
            },
            {
                "name": "container",
                "description": "Container names or IDs",
                "required": true,
                "kind": "str",
                "repeatable": true
            }
        ]
    },
    "rm": {
        "exe": "rm",
        "description": "Remove containers",
        "args": [
            {
                "name": "--force",
                "description": "Force remove running container",
                "kind": "flag"
            },
            {
                "name": "--volumes",
                "description": "Remove anonymous volumes",
                "kind": "flag"
            },
            {
                "name": "container",
                "description": "Container names or IDs",
                "required": true,
                "kind": "str",
                "repeatable": true
            }
        ]
    }
}